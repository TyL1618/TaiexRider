<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Google Play Billing（鑽石購買/永久去廣告 IAP）必要權限 -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <!-- AdMob SDK 讀取廣告 + 本機 loopback server（AdBridgeService）必要權限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.TaiexRider">

        <!-- assetlinks.json 的本機鏡像，官方 TWA/Play Billing 範例都有宣告這塊，
             原本缺漏，補上一起排查 getDetails() 失敗問題 -->
        <meta-data
            android:name="asset_statements"
            android:resource="@string/asset_statements" />

        <!-- AdMob App ID（真實值，測試階段仍用真的 App ID，只有廣告單元 ID 用 Google
             測試單元，見 AdActivity.kt 檔頭說明） -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-8981745966447649~3758790919" />

        <activity
            android:name=".MainActivity"
            android:exported="true">

            <meta-data
                android:name="android.support.customtabs.trusted.DEFAULT_URL"
                android:value="@string/twa_url" />

            <meta-data
                android:name="android.support.customtabs.trusted.DISPLAY_MODE"
                android:value="sticky-immersive" />

                <!-- ⚠️ 必須用 android:resource 引用 @color，不能用 android:value 塞色碼字面值：
                 androidbrowserhelper 會把讀到的 int 當資源 ID 查表，
                 字面值 → Resources$NotFoundException 啟動即崩（vc9 事故根因） -->
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_SCREEN_BACKGROUND_COLOR"
                android:resource="@color/color_splash_bg" />

            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_SCREEN_FADE_OUT_DURATION"
                android:value="300" />

            <!-- Splash 品牌圖（v0.12.6）：splash 期間置中顯示的 icon，
                 需搭配下方 FileProvider 把圖傳給 Chrome -->
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_IMAGE_DRAWABLE"
                android:resource="@drawable/splash_icon" />

            <meta-data
                android:name="android.support.customtabs.trusted.FILE_PROVIDER_AUTHORITY"
                android:value="@string/provider_authority" />

            <!-- 長按圖示 App 捷徑（每日排名賽 / 隨機拉霸） -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="taiexrider.pages.dev" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.google.androidbrowserhelper.trusted.ManageDataLauncherActivity"
            android:exported="false" />

        <!-- 自訂子類別（見 DelegationService.kt），預設實作不會接上 Play Billing
             的 Digital Goods 處理器，一定要換成自己的子類別 + 這個 intent-filter，
             Chrome 才找得到人處理 getDetails()/listPurchases()。
             ⚠️ 絕對不能加 android:permission="android.permission.BIND_JOB_SERVICE"：
             那是系統簽章權限，Chrome 沒有 → 會被擋在 bindService() 那一關，
             getDetails() 直接失敗（vc12/13 卡關真因）。Google 官方 twa-play-billing
             範例的這個 service 就是「exported=true + 只有 intent-filter，無 permission」，
             呼叫端身分驗證由 TrustedWebActivityService 內部比對簽章完成，不靠這個權限。 -->
        <service
            android:name=".DelegationService"
            android:exported="true">
            <intent-filter>
                <action android:name="android.support.customtabs.trusted.TRUSTED_WEB_ACTIVITY_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <!-- Play Billing 付款橋接元件（androidbrowserhelper:billing），
             Chrome 透過這兩個元件跟 Play Billing 溝通付款流程。 -->
        <activity
            android:name="com.google.androidbrowserhelper.playbilling.provider.PaymentActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:configChanges="keyboardHidden|keyboard|orientation|screenLayout|screenSize"
            android:exported="true">
            <intent-filter>
                <action android:name="org.chromium.intent.action.PAY" />
            </intent-filter>
            <meta-data
                android:name="org.chromium.default_payment_method_name"
                android:value="https://play.google.com/billing" />
        </activity>

        <service
            android:name="com.google.androidbrowserhelper.playbilling.provider.PaymentService"
            android:exported="true">
            <intent-filter>
                <action android:name="org.chromium.intent.action.IS_READY_TO_PAY" />
            </intent-filter>
        </service>

        <!-- AdMob 獎勵廣告橋接（見 AdBridgeService.kt 檔頭說明）：
             MainActivity 啟動時 startService 這支，網頁用 fetch(http://127.0.0.1:PORT/...)
             呼叫；不對外 export，只有本機 loopback 能連到，另有 socket 綁 127.0.0.1 把關。 -->
        <service
            android:name=".AdBridgeService"
            android:exported="false" />

        <!-- 收到廣告請求後被 AdBridge.requestRewardedAd() 啟動、實際載入/顯示 RewardedAd
             的透明畫面，沒有自己的 UI，廣告播完/失敗就 finish() 回到原本的 TWA。 -->
        <activity
            android:name=".AdActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- androidbrowserhelper splash 圖傳遞用 FileProvider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="@string/provider_authority"
            android:grantUriPermissions="true"
            android:exported="false">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths" />
        </provider>

    </application>

</manifest>
